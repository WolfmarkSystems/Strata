[workspace]
resolver = "2"
members = [
    "apps/tree/vantor-tree",
    "crates/vantor-shield-engine",
    "crates/vantor-shield-cli",
    "apps/tree/vt-core",
    "apps/tree/vt-cli",
    "apps/tree/vt-index",
    "apps/tree/vt-snapshot",
    "apps/forge/apps/vantor-forge-desktop/src-tauri",
    "crates/vantor-acquire",
    "crates/vantor-artifacts",
    "crates/vantor-core",
    "crates/vantor-forge-core",
    "crates/vantor-fs",
    "crates/vantor-insight",
    "crates/vantor-plugin-sdk",
    "plugins/vantor-plugin-index",
    "plugins/vantor-plugin-chronicle",
    "plugins/vantor-plugin-trace",
    "plugins/vantor-plugin-cipher",
    "plugins/vantor-plugin-remnant",
    "plugins/vantor-plugin-tree-example",
    "crates/vantor-tree-sdk", "crates/vantor-license", "tools/wolfmark-license-gen",
]

[workspace.dependencies]
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
thiserror = "1.0"
anyhow = "1.0"
time = { version = "0.3", features = ["serde", "macros", "formatting", "parsing"] }
uuid = { version = "1.6", features = ["v4", "serde"] }
chrono = { version = "0.4", features = ["serde"] }
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter"] }
tokio = { version = "1.0", features = ["full"] }
libloading = "0.8"
libc = "0.2"
arc-swap = "1.6"
notify = "6.0"
rusqlite = { version = "0.30", features = ["bundled", "functions"] }
[target.'cfg(windows)'.dependencies
evtx = "0.8"
ntfs = "0.4"
sha2 = "0.10"
sha1 = "0.10"
md-5 = "0.10"
blake3 = "1.5"
Tera = "1.19"
regex = "1.10"
sysinfo = "0.33"
memmap2 = "0.9"
plist = "1.7"
tar = "0.4"
flate2 = "1.0"
zip = "2.0"
ewf = "0.1"
serde_yaml = "0.9"
tempfile = "3.8"
rayon = "1.8"

# INTERNAL VANTOR CRATES (CANONICAL NAMES)
vantor-core = { path = "crates/vantor-core" }
vantor-fs = { path = "crates/vantor-fs" }
vantor-plugin-sdk = { path = "crates/vantor-plugin-sdk" }
vantor-acquire = { path = "crates/vantor-acquire" }
vantor-artifacts = { path = "crates/vantor-artifacts" }
vantor-insight = { path = "crates/vantor-insight" }
vantor-forge-core = { path = "crates/vantor-forge-core" }
vantor-shield-engine = { path = "crates/vantor-shield-engine" }
vantor-shield-cli = { path = "crates/vantor-shield-cli" }
vt-core = { path = "apps/tree/vt-core" }
