{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Strata",
  "version": "0.3.0",
  "identifier": "systems.wolfmark.strata",
  "build": {
    "frontendDist": "../../strata-ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../strata-ui && npm run dev",
    "beforeBuildCommand": "cd ../strata-ui && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Strata",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
