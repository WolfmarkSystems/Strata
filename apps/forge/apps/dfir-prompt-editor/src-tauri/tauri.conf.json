{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "DFIR Prompt Editor",
    "version": "0.1.0",
    "identifier": "com.dfir.prompteditor",
    "build": {
        "frontendDist": "../src"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "DFIR Prompt Editor",
                "width": 700,
                "height": 600,
                "resizable": true,
                "center": true
            }
        ],
        "security": {
            "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
        }
    },
    "bundle": {
        "active": true,
        "targets": "all"
    }
}
