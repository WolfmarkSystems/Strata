{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://strata.dev/contracts/evidence.manifest.schema.json",
  "title": "Strata Evidence Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "case_id",
    "evidence_id",
    "source",
    "hashes",
    "ingested_at_utc"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "case_id": { "type": "string", "minLength": 1 },
    "evidence_id": { "type": "string", "minLength": 1 },
    "source": {
      "type": "object",
      "required": ["type", "path", "size_bytes"],
      "properties": {
        "type": { "type": "string" },
        "path": { "type": "string" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "container_type": { "type": "string" }
      },
      "additionalProperties": true
    },
    "hashes": {
      "type": "object",
      "properties": {
        "sha256": { "type": "string" },
        "sha1": { "type": "string" },
        "md5": { "type": "string" }
      },
      "additionalProperties": true
    },
    "ingested_at_utc": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": true
}
